# Discord Bot Token
TOKEN=your_discord_bot_token_here

# Database Configuration
# Set DB_TYPE to: sqlite, mysql, or postgres
DB_TYPE=sqlite

# For SQLite: the bot.db file will be used automatically (no additional config needed)

# For MySQL/PostgreSQL:
# DB_HOSTNAME=localhost
# DB_USERNAME=root
# DB_PASSWORD=your_password
# DB_NAME=discord_bot_db
